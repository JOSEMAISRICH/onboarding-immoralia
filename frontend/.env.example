# Copiar a .env en esta carpeta (frontend/). Reiniciar npm run dev tras cualquier cambio.
# Vite solo inyecta variables con prefijo VITE_ al arrancar el servidor de desarrollo.

VITE_API_URL=http://localhost:3000
VITE_DEV_USER_ID=dev-local-1

# Opcional: si existe, tiene prioridad sobre X-Dev-User-Id (p. ej. session.access_token de Supabase).
# VITE_AUTH_TOKEN=

# Opcional: enlace a workspace / lista / doc de ClickUp (ficha Teoria → ClickUp muestra boton "Abrir ClickUp").
# VITE_CLICKUP_THEORY_URL=https://app.clickup.com/t/TU_WORKSPACE
