# Copiar a .env en esta carpeta (frontend/). Reiniciar npm run dev tras cualquier cambio.
# Vite solo inyecta variables con prefijo VITE_* al arrancar el servidor de desarrollo.

# --- URL del API (obligatoria para ver "API: sí" en la barra) ---
# Solo base: esquema + host + puerto. Sin path tipo /api al final.
# Sin barra final al final (si la pones, el cliente la quita en onboarding.js).
# Ejemplo si Express escucha en 3000: http://localhost:3000
VITE_API_URL=http://localhost:3000

# --- Autenticación ---
# Desarrollo: cabecera X-Dev-User-Id; el backend debe tener ALLOW_DEV_AUTH=true y NODE_ENV=development.
VITE_DEV_USER_ID=dev-local-1

# Producción / pruebas con JWT: si existe, sustituye a X-Dev-User-Id (Authorization: Bearer …).
# VITE_AUTH_TOKEN=

# --- Checklist si algo falla ---
# - Backend levantado en el mismo puerto que VITE_API_URL.
# - CORS: si abres el front en otro origen (p. ej. http://localhost:5173), el Express debe
#   permitir ese origen (Access-Control-Allow-Origin / credentials según toque).
# - En Red del navegador: fallo de red ≠ 401; 401 suele ser JWT ausente o inválido sin dev-auth.

# Opcional: enlace a workspace / lista / doc de ClickUp (ficha Teoria → ClickUp muestra boton "Abrir ClickUp").
# VITE_CLICKUP_THEORY_URL=https://app.clickup.com/t/TU_WORKSPACE

# Opcional (v2): URL publica de un JSON con preguntas / contenido. Ver src/lib/loadContentJson.js
# VITE_CONTENT_JSON_URL=https://docs.google.com/spreadsheets/d/e/XXXX/pub?output=csv
